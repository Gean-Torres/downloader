FROM python:3.12-slim

# 1. Install system dependencies (Heavy, rarely changes)
RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    atomicparsley \
    curl \
    unzip \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# 2. Install Deno (Rarely changes)
RUN curl -fsSL https://deno.land/x/install/install.sh | sh
ENV DENO_INSTALL="/root/.deno"
ENV PATH="$DENO_INSTALL/bin:$PATH"

WORKDIR /app

# 3. Install Python requirements (Changes only when requirements.txt does)
# By copying only this file, we cache the expensive pip install layer
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 4. Copy application code (Changes frequently)
# This layer is now at the very end, so only these lines run during code edits
COPY . .

RUN mkdir -p /downloads

EXPOSE 5000

ENV DOWNLOAD_DIR=/downloads \
    PYTHONUNBUFFERED=1

CMD ["gunicorn", "--bind", "0.0.0.0:5000", "--workers", "1", "--threads", "4", "--worker-class", "gthread", "--timeout", "0", "main:app"]
